{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["src/**", "tsconfig.json", "package.json"],
            "outputs": ["dist/**"]
        },
        "test": {
            "dependsOn": ["build", "^build"],
            "inputs": ["src/**", "tests/**", "vitest.config.ts", "package.json"],
            "outputs": []
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        }
    }
}
